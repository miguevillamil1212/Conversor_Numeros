# Archivo: bienesraices_inicio/public/.htaccess

# Activa el módulo de reescritura
RewriteEngine On

# 1. Condición: Si el archivo solicitado NO existe en el sistema de archivos
RewriteCond %{REQUEST_FILENAME} !-f

# 2. Condición: Si el directorio solicitado NO existe
RewriteCond %{REQUEST_FILENAME} !-d

# 3. Regla: Redirige internamente (sin cambiar la URL en el navegador)
# todas las peticiones que pasaron las condiciones anteriores a index.php
RewriteRule ^ index.php [L]